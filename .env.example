# Скопируй в .env для локального запуска (в Actions это задаётся через Secrets).
# В PowerShell локально удобнее задать через $env:ИМЯ = "значение".

TRAVELPAYOUTS_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Необязательное — есть значения по умолчанию:
# ORIGIN=PEE
# DESTINATION=MOW
# MONTHS=2026-07,2026-08
# CURRENCY=rub
# MIN_STAY=7            # минимум дней в Москве (обратный билет не раньше)
# MAX_STAY=14           # максимум дней в Москве
# DROP_THRESHOLD=0.15   # на сколько ниже средней цены пары считать «дёшево»
# MAX_ALERTS=5          # сколько пар класть в одно уведомление
# DIRECT_ONLY=true      # только прямые рейсы (без пересадок)
# MAX_PRICE=0           # потолок цены одного билета (0 = выкл)
